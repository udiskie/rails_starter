# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# Ignore bundler config.
/.bundle

# Ignore the default SQLite database.
/db/*.sqlite3
/db/*.sqlite3-journal
/db/*.sqlite3-*

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore uploaded files in development.
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

/public/assets
.byebug_history

# Ignore master key for decrypting credentials and other encrypted files.
/config/master.key

# Environment variables
.env
.env.*
!.env.example

# Editor / OS junk
.DS_Store
*.swp
*.swo
.vscode/
.idea/

# Node modules (if using jsbundling/cssbundling or importmap with npm packages)
/node_modules
/app/assets/builds/*
!/app/assets/builds/.keep

# Yarn
/public/packs
/public/packs-test
yarn-debug.log*
.yarn-integrity

# Docker (if applicable)
docker-compose.override.yml

# Coverage / test artifacts
/coverage/

# RSpec / test reports
/spec/reports/
/spec/examples.txt